# Dev-tooling for this repo's own primary-checkout sync invariants.
# Hooks and the sync/check scripts only do anything useful when run
# inside a pi-mmr git checkout; they have no purpose when pi-mmr is
# installed as a Pi extension into a downstream environment.
.githooks/
scripts/sync-primary.sh
scripts/check-primary-fresh.sh
scripts/install-hooks.mjs

# Developer-only debug-capture extension. Not registered in package.json
# pi.extensions, so it never auto-loads for users; excluded here so it is
# never shipped in the npm package either.
src/extensions/mmr-debug/
